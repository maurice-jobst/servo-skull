[Unit]
Description=Servo-Skull Background Worker Service (Servitor)
After=network.target

[Service]
Type=simple
User=servo-skull
# NOTE: Adjust WorkingDirectory, ExecStart, and User to match your environment.
WorkingDirectory=/opt/servo-skull
ExecStart=/opt/servo-skull/.venv/bin/servo-skull-worker
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
